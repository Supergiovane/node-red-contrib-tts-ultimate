{
  "name": "node-red-contrib-tts-ultimate",
  "version": "3.1.1",
  "description": "Transforms the text in speech and hear it using Sonos player or generate an audio file to be used with third parties nodes. Works with voices from Google (without credentials as well), Google TTS, ElevenLabs.io TTS, Voice.ai TTS or your own voice. You can also only create a TTS file to be read by third party nodes. Update of the popular SonosPollyTTS node.",
  "main": "index.js",
  "scripts": {
    "test": "test",
    "verify:googletranslate-split": "node scripts/verify-googletranslate-split.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Supergiovane/node-red-contrib-tts-ultimate.git"
  },
  "keywords": [
    "node-red",
    "google",
    "voice",
    "tts",
    "sonos",
    "IOT",
    "speech",
    "ttsultimate",
    "sonospollytts",
    "neural",
    "elevenlabs",
    "voiceai"
  ],
  "node-red": {
    "nodes": {
      "ttsultimate": "ttsultimate/ttsultimate.js",
      "ttsultimate-config": "ttsultimate/ttsultimate-config.js",
      "ownfile": "ttsultimate/ownfileultimate.js"
    }
  },
  "author": "Supergiovane",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Supergiovane/node-red-contrib-tts-ultimate"
  },
  "homepage": "https://github.com/Supergiovane/node-red-contrib-tts-ultimate",
  "dependencies": {
    "@google-cloud/text-to-speech": "4.2.2",
    "elevenlabs": "0.18.0",
    "elevenlabs-node": "1.1.3",
    "formidable": "1.2.2",
    "sonos": "1.14.1"
  },
  "devDependencies": {
    "eslint": ">=4.18.2",
    "eslint-config-google": "^0.7.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
